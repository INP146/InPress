{
  "name": "@inp146/inpress",
  "version": "0.1.0",
  "description": "InPress, a reusable theme extending the VitePress default theme.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.js"
    },
    "./playground": {
      "types": "./dist/playground.d.ts",
      "import": "./dist/playground.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "check": "vue-tsc --noEmit && tsx --test test/*.test.ts"
  },
  "peerDependencies": {
    "vitepress": "^2.0.0-alpha.18",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vite": "^8.1.4",
    "vitepress": "2.0.0-alpha.18",
    "vue-tsc": "^3.3.7"
  },
  "dependencies": {
    "culori": "^4.0.2"
  }
}
